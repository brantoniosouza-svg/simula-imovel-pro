# ===== SERVER =====
PORT=3000
NODE_ENV=development

# ===== DATABASE =====
DATABASE_URL=postgresql://simula_user:simula_password@postgres:5432/simula_imovel
REDIS_URL=redis://redis:6379
MONGODB_URL=mongodb://admin:password@mongodb:27017/simula_imovel

# ===== JWT =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ===== STRIPE =====
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===== SENDGRID =====
SENDGRID_API_KEY=SG.your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@simulaimovel.com

# ===== AWS =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=simula-imovel-reports

# ===== MANUS AI =====
MANUS_API_KEY=your_manus_api_key
MANUS_API_URL=https://api.manus.ai

# ===== APP =====
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ===== DATABASE CREDENTIALS =====
DB_USER=simula_user
DB_PASSWORD=simula_password
DB_NAME=simula_imovel
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=simula_imovel
